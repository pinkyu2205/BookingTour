<Window x:Class="ChatApp.Views.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ChatApp" Height="680" Width="960"
        MinHeight="500" MinWidth="720"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDeepBrush}"
        WindowStyle="None"
        AllowsTransparency="True"
        Closing="Window_Closing">

    <Border CornerRadius="14" Background="{StaticResource BgDeepBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.7" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>      <!-- Title bar -->
                <RowDefinition Height="*"/>       <!-- Body -->
                <RowDefinition Height="Auto"/>    <!-- Status bar -->
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0"
                    MouseDown="TitleBar_MouseDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#141720" Offset="0"/>
                        <GradientStop Color="#0D0F14" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- App icon + name -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                        <TextBlock Text="💬" FontSize="20" VerticalAlignment="Center"/>
                        <TextBlock Text="ChatApp" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="8,0,0,0" FontFamily="Segoe UI"/>
                        <Border Background="#6C63FF" CornerRadius="6" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="# general" FontSize="11" Foreground="White" FontFamily="Segoe UI" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>

                    <!-- User info -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource GreenBrush}" Margin="0,0,6,0"/>
                        <TextBlock x:Name="TxtCurrentUser" Text="You" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                                   FontFamily="Segoe UI"/>
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                        <Button x:Name="BtnMinimize" Content="—" Click="BtnMinimize_Click"
                                Width="32" Height="32"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TextMutedBrush}" FontSize="13" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" CornerRadius="6" Background="Transparent" Width="32" Height="32">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#1E2434"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="✕" Click="CloseButton_Click"
                                Width="32" Height="32" Margin="4,0,8,0"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TextMutedBrush}" FontSize="13" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" CornerRadius="6" Background="Transparent" Width="32" Height="32">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource RedBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- BODY -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>   <!-- Sidebar -->
                    <ColumnDefinition Width="*"/>      <!-- Chat area -->
                </Grid.ColumnDefinitions>

                <!-- SIDEBAR -->
                <Border Grid.Column="0" Background="#10131B"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Sidebar header -->
                        <Border Grid.Row="0" Padding="16,14" 
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                            <StackPanel>
                                <TextBlock Text="ONLINE" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="Segoe UI" Margin="0,0,0,2"/>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="7" Height="7" Fill="{StaticResource GreenBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtOnlineCount" Text="0 users"
                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- User list -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="UserList" Margin="8,8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="8" Padding="10,8" Margin="0,2">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource BgHoverBrush}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <!-- Avatar circle -->
                                                <Border Width="32" Height="32" CornerRadius="10">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#6C63FF" Offset="0"/>
                                                            <GradientStop Color="#A78BFA" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <TextBlock Text="{Binding Converter={StaticResource InitialConverter}}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontSize="13" FontWeight="Bold" Foreground="White" FontFamily="Segoe UI"/>
                                                </Border>
                                                <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding}" FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- CHAT AREA -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Messages -->
                    <ScrollViewer x:Name="MessagesScroll" Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="16,12">
                        <StackPanel x:Name="MessagesPanel"/>
                    </ScrollViewer>

                    <!-- Input area -->
                    <Border Grid.Row="1" Padding="16,12"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                            Background="#0E1118">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtMessage" Grid.Column="0"
                                     Style="{StaticResource DarkTextBox}"
                                     Height="44" Margin="0,0,10,0"
                                     VerticalContentAlignment="Center"
                                     KeyDown="TxtMessage_KeyDown"
                                     MaxLength="500"/>
                            <Button x:Name="BtnSend" Grid.Column="1"
                                    Style="{StaticResource SendButton}"
                                    Click="BtnSend_Click"
                                    ToolTip="Send (Enter)">
                                <TextBlock Text="➤" FontSize="16"/>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- STATUS BAR -->
            <Border Grid.Row="2" Padding="16,6"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,14,14" Background="#0A0C12">
                <TextBlock x:Name="TxtStatus" Text="Connected"
                           FontSize="11" Foreground="{StaticResource GreenBrush}"
                           FontFamily="Segoe UI"/>
            </Border>
        </Grid>
    </Border>

    <!-- Resize grip -->
    <Window.TaskbarItemInfo>
        <TaskbarItemInfo/>
    </Window.TaskbarItemInfo>
</Window>
